+    pub(super) fn xorg_raw_to_evdev_code(raw: u16) -> Option<c_int> {
+        raw.checked_sub(8).and_then(|code| {
+            if code as usize <= KEY_MAX {
+                Some(code as c_int)
+            } else {
+                None
+            }
+        })
+    }
+
+    const KEY_ESC: c_int = 1;
+    const KEY_CAPSLOCK: c_int = 58;
+    const KEY_NUMLOCK: c_int = 69;
+    const KEY_MICMUTE: c_int = 248;
+    const KEY_MAX: usize = 0x2ff;
+    const KEY_CNT: usize = KEY_MAX + 1;
+
+    pub struct UInputKeyboardManager {
+        uinput_file: File,
+        pressed: Vec<bool>,
+        caps_lock: bool,
+        num_lock: bool,
+    }
+
+    impl UInputKeyboardManager {
+        pub fn new() -> Result<Self> {
+            let manager = UInputKeyboardManager {
+                uinput_file: File::options()
+                    .write(true)
+                    .custom_flags(O_NONBLOCK)
+                    .open("/dev/uinput")?,
+                pressed: vec![false; KEY_CNT],
+                caps_lock: false,
+                num_lock: false,
+            };
+            let fd = manager.uinput_file.as_raw_fd();
+            unsafe {
+                ioctl(fd, UI_SET_EVBIT, EV_KEY);
+                for key in KEY_ESC..=KEY_MICMUTE {
+                    ioctl(fd, UI_SET_KEYBIT, key);
+                }
+            }
+
+            manager.setup_device(fd)?;
+
+            // Give userspace time to discover the new input node before events arrive.
+            thread::sleep(Duration::from_millis(300));
+
+            Ok(manager)
+        }
+
+        fn setup_device(&self, fd: c_int) -> Result<()> {
+            let name = keyboard_device_name();
+            let id = InputId {
+                bustype: BUS_USB,
+                vendor: 0x5255,
+                product: 0x4b42,
+                version: 1,
+            };
+
+            let usetup = UInputSetup {
+                id,
+                name,
+                ff_effects_max: 0,
+            };
+
+            let modern_ok = unsafe { ioctl(fd, UI_DEV_SETUP, &usetup) } >= 0;
+            if !modern_ok {
+                let legacy = UinputUserDev {
+                    name,
+                    id,
+                    ff_effects_max: 0,
+                    absmax: [0; ABS_CNT],
+                    absmin: [0; ABS_CNT],
+                    absfuzz: [0; ABS_CNT],
+                    absflat: [0; ABS_CNT],
+                };
+                self.write_raw(&legacy)?;
+            }
+
+            if unsafe { ioctl(fd, UI_DEV_CREATE) } < 0 {
+                return Err(Error::last_os_error());
+            }
+            Ok(())
+        }
+
+        fn emit(&self, r#type: c_int, code: c_int, value: c_int) -> Result<()> {
+            let event = InputEvent {
+                time: TimeVal {
+                    tv_sec: 0,
+                    tv_usec: 0,
+                },
+                r#type: r#type as c_ushort,
+                code: code as c_ushort,
+                value,
+            };
+            self.write_raw(&event)
+        }
+
+        fn write_raw<T>(&self, value: &T) -> Result<()> {
+            let fd = self.uinput_file.as_raw_fd();
+
+            unsafe {
+                let count = size_of::<T>();
+                let written_bytes = write(fd, value as *const T as *const c_void, count);
+                if written_bytes == -1 || written_bytes != count as c_long {
+                    return Err(Error::new(
+                        ErrorKind::Other,
+                        format!("failed while trying to write to a file"),
+                    ));
+                }
+            }
+
+            Ok(())
+        }
+
+        fn syncronize(&self) -> Result<()> {
+            self.emit(EV_SYN, SYN_REPORT, 0)
+        }
+
+        pub fn set_key(&mut self, code: c_int, down: bool) -> Result<()> {
+            if code < 0 || code as usize >= self.pressed.len() {
+                return Ok(());
+            }
+
+            let index = code as usize;
+            let was_down = self.pressed[index];
+            self.emit(EV_KEY, code, if down { 1 } else { 0 })?;
+            self.syncronize()?;
+            self.pressed[index] = down;
+
+            if down && !was_down {
+                match code {
+                    KEY_CAPSLOCK => self.caps_lock = !self.caps_lock,
+                    KEY_NUMLOCK => self.num_lock = !self.num_lock,
+                    _ => {}
+                }
+            }
+
+            Ok(())
+        }
+
+        pub fn is_key_pressed(&self, code: c_int) -> bool {
+            if code < 0 || code as usize >= self.pressed.len() {
+                return false;
+            }
+            self.pressed[code as usize]
+        }
+
+        pub fn caps_lock_state(&self) -> bool {
+            self.caps_lock
+        }
+
+        pub fn num_lock_state(&self) -> bool {
+            self.num_lock
+        }
+    }
+
